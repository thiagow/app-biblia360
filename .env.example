# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://quiz_user:change-me-strong-password@localhost:5432/quiz_db

# Used by docker-compose to initialize postgres (dev only)
POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=quiz_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Admin user ────────────────────────────────────────────────────────────────
# Create admin via: npx tsx scripts/create-admin.ts <email> <password>
